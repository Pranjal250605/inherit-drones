    "h2_emph": "questions.",
    "subtitle_jp": "よくあるご質問",
    "lead": "Technical, regulatory, and commercial — replies within one business day.",
    "items": [
      {
        "q": "Where do you currently operate?",
        "a": "Hiroshima, Okayama, Ehime, and Yamaguchi — and the rest of Japan by request."
      },
      {
        "q": "Are your BVLOS operations approved by MLIT?",
        "a": "Yes — Level 4 BVLOS authorisation, Type-2 airframe, certified remote pilots."
      },
      {
        "q": "How do you handle data sovereignty?",
        "a": "All data stored and processed on encrypted, Japan-resident infrastructure, owned by you."
      },
      {
        "q": "Do you sell the IH-04 platform?",
        "a": "No. We deliver flight-as-a-service — platform, pilots, ground stations, and data."
      },
      {
        "q": "What does engagement look like?",
        "a": "A scoping call, a paid pilot mission, then an annual contract. Flying within 30 days."
      }
    ]
