      },
      {
        "code": "N.02",
        "date": "2026.04.02",
        "category": "Announcement",
        "category_jp": "お知らせ",
        "title": "NAPA Drone Academy welcomes the 2026 spring cohort",
        "excerpt": "Twenty-two new pilots begin the rigorous Type-2 BVLOS certification programme at the Hiroshima campus. The 12-week curriculum covers autonomous waypoint navigation, sensor integration, and emergency procedures across all weather conditions.",
        "img": "team-napa"
      },
      {
        "code": "N.01",
        "date": "2026.01.22",
        "category": "Press Release",
        "category_jp": "プレスリリース",
        "title": "BVLOS Level-4 corridor extension approved for Hiroshima Bay",
        "excerpt": "MLIT has approved a 64 km coastal corridor extension over Hiroshima Bay, enabling uninterrupted BVLOS operations between the mainland and six outer islands. This marks the longest single-operator BVLOS route approved in Japan.",
        "img": "bvlos-corridor"
      }
